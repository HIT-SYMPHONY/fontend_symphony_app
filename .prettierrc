{
  "arrowParens": "always",
  "tabWidth": 2,
  "semi": false,
  "bracketSameLine": true,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "useTabs": false,
  "singleQuote": true,
  "embeddedLanguageFormatting": "auto",
  "proseWrap": "preserve",
  "trailingComma": "all",
  "quoteProps": "as-needed",
  "plugins": ["prettier-plugin-tailwindcss"],
  "printWidth": 80
}
